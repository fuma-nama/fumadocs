{
  "name": "example-react-router-i18n",
  "private": true,
  "type": "module",
  "imports": {
    "#/collections/*": "./.source/*",
    "#/*": "./app/*"
  },
  "scripts": {
    "build": "node scripts/generate-info.ts && react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@fumadocs/language": "workspace:*",
    "@orama/tokenizers": "^3.1.18",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "fumadocs-core": "workspace:*",
    "fumadocs-mdx": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "isbot": "^5.1.44",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1"
  },
  "devDependencies": {
    "@react-router/dev": "^8.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
