{
  "name": "root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:examples": "turbo run dev --filter=./examples/*",
    "lint": "turbo run lint",
    "lint:format": "oxfmt --check",
    "format": "oxfmt",
    "test": "vitest",
    "tegami": "node tegami.ts",
    "types:check": "turbo run types:check --continue"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "rimraf": "^6.1.3",
    "tegami": "^1.2.5",
    "tinyexec": "^1.2.4",
    "turbo": "2.10.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">= 24.14.0"
  },
  "packageManager": "pnpm@11.5.3"
}
