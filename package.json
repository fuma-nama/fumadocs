{
  "name": "root",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:examples": "turbo run dev --filter=./examples/*",
    "sync-ui": "bash ./scripts/mirror-ui-change.sh",
    "lint": "turbo run lint",
    "lint:format": "oxfmt --check",
    "format": "oxfmt",
    "release": "turbo run build --filter=./packages/* && changeset publish && pnpm -r run postpublish",
    "test": "vitest",
    "types:check": "turbo run types:check --continue",
    "version": "changeset version && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "bun": "1.3.11",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "rimraf": "^6.1.3",
    "turbo": "2.9.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">= 18.17.0"
  },
  "packageManager": "pnpm@10.18.3"
}
