{
  "name": "@fumapress/ai",
  "version": "0.2.0",
  "private": true,
  "description": "AI integration for Fumapress",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist",
    "css"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./components/search": "./dist/components/search.mjs",
    "./package.json": "./package.json",
    "./css/preset.css": "./css/preset.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.178",
    "@radix-ui/react-presence": "^1.1.5",
    "ai": "^6.0.176",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "fumapress": "workspace:*",
    "lucide-react": "^1.14.0",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/oxide": "^4.2.4",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3",
    "waku": "1.0.0-alpha.10"
  },
  "peerDependencies": {
    "@types/react": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "waku": "1.0.0-alpha.9"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
