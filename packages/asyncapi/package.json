{
  "name": "@fumadocs/asyncapi",
  "version": "0.2.1",
  "description": "Generate docs for your AsyncAPI spec",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "css",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./i18n": "./dist/i18n.js",
    "./server": "./dist/server/index.js",
    "./ui": "./dist/ui/index.js",
    "./package.json": "./package.json",
    "./css/*": "./css/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fuma-translate/react": "^1.0.2",
    "@fumadocs/api-docs": "workspace:*",
    "@fumari/json-schema-ts": "^1.0.2",
    "@fumari/stf": "workspace:*",
    "@scalar/json-magic": "^0.12.17",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "github-slugger": "^2.0.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^1.24.0",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/oxide": "^4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:@fumadocs/base-ui@*",
    "json-schema-typed": "^8.0.2",
    "tailwindcss": "^4.3.2",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.8"
  },
  "peerDependencies": {
    "@types/react": "*",
    "fumadocs-core": "^16.9.0",
    "fumadocs-ui": "^16.9.0",
    "json-schema-typed": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "json-schema-typed": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  }
}
