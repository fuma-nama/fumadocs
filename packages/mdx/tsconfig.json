{
  "extends": "tsconfig/base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "fumadocs-mdx/macro": ["./src/macro/index.ts"],
      "@fumadocs/satteri/*": ["../satteri/dist/*"]
    },
    "types": ["@types/node", "@types/mdx", "@fumadocs/satteri"],
    "jsx": "react-jsx",
    "noEmit": true,
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ES2020"
  },
  "exclude": ["node_modules", "eslint.config.mjs", "dist", "test/fixtures/**/*.output.ts"]
}
