{
  "name": "@fumadocs/content",
  "version": "0.0.3",
  "description": "The Fuma Content adapter for Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/runtime.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fuma-content": "^1.2.3",
    "fumadocs-core": "workspace:*",
    "react-dom": "^19.2.5",
    "tsconfig": "workspace:*",
    "tsdown": "0.21.7"
  },
  "peerDependencies": {
    "fuma-content": "^1.2.3",
    "fumadocs-core": "^16.6.17"
  }
}
