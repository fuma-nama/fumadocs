{
  "name": "fumapress",
  "version": "0.1.10",
  "description": "Opinionated Fumadocs for fast content preview",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "bin": {
    "fumapress": "./dist/lib/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./config": "./dist/lib/config/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "waku build && tsdown",
    "dev:app": "waku dev",
    "build:app": "waku build",
    "start:app": "waku start",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@takumi-rs/image-response": "^0.71.7",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "tinyglobby": "^0.2.15",
    "unrun": "^0.2.32",
    "waku": "1.0.0-alpha.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "beautiful-mermaid": "^1.1.3",
    "gray-matter": "^4.0.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "hono": "^4.12.7",
    "ignore": "^7.0.5",
    "katex": "0.16.38",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-server-dom-webpack": "^19.2.4",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsdown": "0.21.2",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
