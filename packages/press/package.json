    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "remark-gfm": "^4.0.1",
    "tinyglobby": "^0.2.15",
    "unist-util-visit": "^5.1.0",
