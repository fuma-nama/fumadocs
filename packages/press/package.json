{
  "name": "fumapress",
  "version": "0.1.20",
  "description": "Opinionated Fumadocs for fast content preview",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
