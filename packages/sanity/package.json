{
  "name": "@fumadocs/sanity",
  "version": "0.0.5",
  "description": "The official Sanity integration for Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./client": "./dist/client.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0"
  },
  "devDependencies": {
    "@sanity/client": "^7.23.0",
    "@sanity/types": "^6.3.0",
    "@types/node": "26.1.0",
    "@types/react": "^19.2.17",
    "fuma-cli": "^0.1.1",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:@fumadocs/base-ui@*",
    "next-sanity": "^13.1.1",
    "react": "^19.2.7",
    "sanity": "^6.3.0",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@sanity/client": "^7.22.0",
    "@sanity/types": "*",
    "@types/react": "*",
    "fumadocs-core": "^16.8.0",
    "next-sanity": "^12.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "@sanity/types": {
      "optional": true
    },
    "@sanity/client": {
      "optional": true
    },
    "next-sanity": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  }
}
