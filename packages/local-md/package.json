{
  "name": "@fumadocs/local-md",
  "version": "0.3.2",
  "description": "The local Markdown files content source for Fumadocs",
  "keywords": [
    "Docs",
    "fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "bin": {
    "local-md": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./dev/react-client": "./dist/dev/react-client.js",
    "./dev/vite": "./dist/dev/vite.js",
    "./dev/ws": "./dist/dev/ws.js",
    "./js/executor": "./dist/js/executor.js",
    "./js/executor-native": "./dist/js/executor-native.js",
    "./js/executor-virtual": "./dist/js/executor-virtual.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fumadocs/local-content": "workspace:*",
    "@mdx-js/mdx": "^3.1.1",
    "@standard-schema/spec": "^1.1.0",
    "estree-util-build-jsx": "^3.0.1",
    "estree-util-to-js": "^2.0.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@types/estree": "^1.0.9",
    "@types/estree-jsx": "^1.0.5",
    "@types/hast": "^3.0.5",
    "@types/mdx": "^2.0.14",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "fumadocs-core": "workspace:*",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.13",
    "unified": "^11.0.5",
    "vite": "^8.1.5"
  },
  "peerDependencies": {
    "@types/estree": "*",
    "@types/estree-jsx": "*",
    "@types/hast": "*",
    "@types/mdx": "*",
    "@types/react": "*",
    "fumadocs-core": "^16.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "unified": "*"
  },
  "peerDependenciesMeta": {
    "unified": {
      "optional": true
    },
    "@types/mdx": {
      "optional": true
    },
    "@types/estree": {
      "optional": true
    },
    "@types/estree-jsx": {
      "optional": true
    },
    "@types/hast": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  }
}
