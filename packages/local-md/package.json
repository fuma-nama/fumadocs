{
  "name": "@fumadocs/local-md",
  "version": "0.0.0",
  "description": "The local Markdown files content source for Fumadocs",
  "keywords": [
    "Docs",
    "fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./dev": "./dist/dev/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "chokidar": "^5.0.0",
    "estree-util-to-js": "^2.0.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "remark": "^15.0.1",
    "remark-mdx": "^3.1.1",
    "remark-rehype": "^11.1.2",
    "tinyglobby": "^0.2.16",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@types/estree": "^1.0.8",
    "@types/estree-jsx": "^1.0.5",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "fumadocs-core": "workspace:*",
    "ignore": "^7.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stable-hash": "^0.0.6",
    "tsconfig": "workspace:*",
    "tsdown": "0.21.8"
  },
  "peerDependencies": {
    "@types/hast": "*",
    "@types/mdx": "*",
    "@types/react": "*",
    "@types/unist": "*",
    "fumadocs-core": "^16.7.17",
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "@types/hast": {
      "optional": true
    },
    "@types/unist": {
      "optional": true
    },
    "@types/mdx": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "ignore": "7.0.5",
    "stable-hash": "0.0.6"
  }
}
