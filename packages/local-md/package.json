{
  "name": "@fumadocs/local-md",
  "version": "0.0.0",
  "description": "The local Markdown files content source for Fumadocs",
  "keywords": [
    "Docs",
    "fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "eval-estree-expression": "^3.0.1",
    "ignore": "^7.0.5",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "fumadocs-core": "workspace:*",
    "react": "^19.2.5",
    "tsconfig": "workspace:*",
    "tsdown": "0.21.8"
  },
  "peerDependencies": {
    "@types/mdx": "*",
    "@types/react": "*",
    "fumadocs-core": "^16.7.17",
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "@types/mdx": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
