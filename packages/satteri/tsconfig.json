{
  "extends": "tsconfig/base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["@types/node", "@types/mdast", "@types/hast"],
    "jsx": "react-jsx",
    "noEmit": true,
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ES2023"
  },
  "exclude": ["node_modules", "dist"]
}
