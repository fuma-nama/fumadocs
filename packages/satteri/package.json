    "./inject-exports": "./dist/inject-exports.js",
    "./preset": "./dist/preset.js",
    "./rehype-code": "./dist/rehype-code.js",
    "./rehype-toc": "./dist/rehype-toc.js",
    "./remark-admonition": "./dist/remark-admonition.js",
    "./remark-auto-type-table": "./dist/remark-auto-type-table.js",
    "./remark-block-id": "./dist/remark-block-id.js",
    "./remark-code-tab": "./dist/remark-code-tab.js",
    "./remark-directive-admonition": "./dist/remark-directive-admonition.js",
    "./remark-feedback-block": "./dist/remark-feedback-block.js",
    "./remark-heading": "./dist/remark-heading.js",
    "./remark-image": "./dist/remark-image.js",
    "./remark-llms": "./dist/remark-llms.js",
    "./remark-mdx-mermaid": "./dist/remark-mdx-mermaid.js",
    "./remark-npm": "./dist/remark-npm.js",
    "./remark-steps": "./dist/remark-steps.js",
    "./remark-structure": "./dist/remark-structure.js",
    "./remark-ts2js": "./dist/remark-ts2js.js",
    "./utils": "./dist/utils.js",
    "./package.json": "./package.json"
