{
  "name": "@fumadocs/tailwind",
  "version": "0.1.1",
  "description": "The Tailwind CSS utils for Fumadocs UI.",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./typography": "./dist/typography/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "devDependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@types/node": "^26.1.1",
    "postcss-selector-parser": "^7.1.4",
    "tailwindcss": "^4.3.2",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.8"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "@fastify/deepmerge": "3.2.1",
    "cssesc": "3.0.0",
    "postcss-selector-parser": "7.1.4",
    "util-deprecate": "1.0.2"
  }
}
