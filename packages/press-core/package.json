{
  "name": "@fumapress/core",
  "version": "0.0.1",
  "private": true,
  "description": "An opinionated docs framework powered by Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist",
    "css"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./layouts/root": "./dist/layouts/root.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json",
    "./css/preset.css": "./css/preset.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fumadocs/local-md": "workspace:*",
    "@takumi-rs/image-response": "^1.1.2",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "lucide-react": "^1.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/oxide": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "waku": "1.0.0-alpha.9"
  },
  "peerDependencies": {
    "@types/react": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "waku": "1.0.0-alpha.9"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
