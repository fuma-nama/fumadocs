{
  "name": "@fumapress/core",
  "version": "0.0.1",
  "private": true,
  "description": "An opinionated docs framework powered by Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist",
    "css"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./layouts/docs": "./dist/layouts/docs.mjs",
    "./layouts/home": "./dist/layouts/home.mjs",
    "./plugins": "./dist/plugins/index.mjs",
    "./plugins/llms.txt": "./dist/plugins/llms.txt.mjs",
    "./plugins/orama-search": "./dist/plugins/orama-search.mjs",
    "./plugins/takumi": "./dist/plugins/takumi.mjs",
    "./router": "./dist/router.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json",
    "./css/preset.css": "./css/preset.css",
    "./css/default.css": "./css/default.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@takumi-rs/image-response": "^1.1.2",
    "fumadocs-core": "workspace:*",
    "fumadocs-mdx": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "lucide-react": "^1.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/oxide": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitefu": "^1.1.3",
    "waku": "1.0.0-alpha.10"
  },
  "peerDependencies": {
    "@types/react": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "8.x.x",
    "waku": "1.0.0-alpha.9"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "vitefu": "1.1.3"
  }
}
