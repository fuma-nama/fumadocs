{
  "name": "@fumadocs/api-docs",
  "version": "0.0.4",
  "description": "Shared utils for API docs generation",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "css",
    "dist"
  ],
  "type": "module",
  "exports": {
    "./auto-anchor": "./dist/auto-anchor/index.js",
    "./auto-anchor/client": "./dist/auto-anchor/client.js",
    "./codegen": "./dist/codegen.js",
    "./components/accordion": "./dist/components/accordion.js",
    "./components/dialog": "./dist/components/dialog.js",
    "./components/input": "./dist/components/input.js",
    "./components/playground/inputs": "./dist/components/playground/inputs.js",
    "./components/playground/schema": "./dist/components/playground/schema.js",
    "./components/schema": "./dist/components/schema/index.js",
    "./components/schema/client": "./dist/components/schema/client.js",
    "./components/select": "./dist/components/select.js",
    "./components/select-tab": "./dist/components/select-tab.js",
    "./components/spinner": "./dist/components/spinner.js",
    "./i18n": "./dist/i18n.js",
    "./schema": "./dist/schema/index.js",
    "./schema/bundle": "./dist/schema/bundle.js",
    "./schema/dereference": "./dist/schema/dereference.js",
    "./schema/merge": "./dist/schema/merge.js",
    "./schema/ref": "./dist/schema/ref.js",
    "./schema/resolve-ref": "./dist/schema/resolve-ref.js",
    "./schema/sample": "./dist/schema/sample.js",
    "./schema/to-string": "./dist/schema/to-string.js",
    "./utils/id-to-title": "./dist/utils/id-to-title.js",
    "./utils/url": "./dist/utils/url.js",
    "./package.json": "./package.json",
    "./css/*": "./css/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fuma-translate/react": "^1.0.2",
    "@fumari/stf": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "github-slugger": "^2.0.0",
    "js-yaml": "^5.1.0",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@tailwindcss/oxide": "^4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "^19.2.17",
    "ajv": "^8.20.0",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "json-schema-typed": "^8.0.2",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.3"
  },
  "peerDependencies": {
    "@types/react": "*",
    "fumadocs-core": "^16.9.0",
    "fumadocs-ui": "^16.9.0",
    "json-schema-typed": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "json-schema-typed": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "@fastify/deepmerge": "3.2.1",
    "ajv": "8.20.0",
    "fast-deep-equal": "3.1.3",
    "fast-uri": "3.1.0",
    "json-schema-traverse": "1.0.0"
  }
}
