{
  "name": "fumadocs-epub",
  "version": "1.0.0",
  "description": "EPUB export for Fumadocs documentation",
  "keywords": [
    "documentation",
    "epub",
    "export",
    "fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist/*"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "epub-gen-memory": "^1.1.2",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "25.5.0",
    "fumadocs-core": "workspace:*",
    "rimraf": "^6.0.0",
    "tsconfig": "workspace:*",
    "tsdown": "0.21.6",
    "typescript": "^6.0.2",
    "vfile": "^6.0.3"
  },
  "peerDependencies": {
    "fumadocs-core": "^15.0.0 || ^16.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
