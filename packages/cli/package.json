{
  "name": "@fumadocs/cli",
  "version": "1.3.4",
  "description": "The CLI tool for Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "bin": {
    "fumadocs": "./dist/index.js"
  },
  "files": [
    "dist/*"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/config.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --config-loader unrun",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "fuma-cli": "^0.0.1",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.121.0",
    "oxc-resolver": "^11.19.1",
    "package-manager-detector": "^1.6.0",
    "picocolors": "^1.1.1",
    "tinyexec": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@oxc-project/types": "^0.122.0",
    "@types/node": "25.5.0",
    "shadcn": "4.1.1",
    "tsconfig": "workspace:*",
    "tsdown": "0.21.6"
  }
}
