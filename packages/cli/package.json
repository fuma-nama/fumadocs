{
  "name": "@fumadocs/cli",
  "version": "1.4.0",
  "description": "The CLI tool for Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "bin": {
    "cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./config": "./dist/config.js",
    "./registry/installer": "./dist/registry/installer.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0",
    "fuma-cli": "^0.1.1",
    "picocolors": "^1.1.1",
    "tinyexec": "^1.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.4"
  }
}
