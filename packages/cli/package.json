{
  "name": "@fumadocs/cli",
  "version": "1.3.5",
  "description": "The CLI tool for Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "bin": {
    "fumadocs": "./dist/index.js"
  },
  "files": [
    "dist/*"
  ],
  "type": "module",
  "exports": {
    "./config": "./dist/config.js",
    "./registry/installer": "./dist/registry/installer.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --config-loader unrun",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "fuma-cli": "^0.0.5",
    "picocolors": "^1.1.1",
    "tinyexec": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsconfig": "workspace:*",
    "tsdown": "0.21.7"
  }
}
