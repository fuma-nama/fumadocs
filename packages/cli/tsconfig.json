{
  "extends": "tsconfig/base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ES2020"
  },
  "exclude": ["dist", "node_modules", "test/repo", "test/repo-2", "eslint.config.mjs"]
}
