{
  "name": "@fumadocs/tinacms",
  "version": "0.0.0",
  "description": "The official TinaCMS integration for Fumadocs",
  "keywords": [
    "Docs",
    "Fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./client": "./dist/client.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "^19.2.17",
    "fumadocs-core": "workspace:*",
    "react": "^19.2.7",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@types/react": "*",
    "fumadocs-core": "^16.8.0",
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
