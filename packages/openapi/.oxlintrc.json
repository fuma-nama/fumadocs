{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "import"],
  "env": {
    "builtin": true
  },
  "settings": {
    "react": {
      "version": "18.3.1"
    },
    "tailwindcss": {
      "callees": ["clsx", "cva", "cn"]
    }
  },
  "ignorePatterns": ["dist/", "node_modules/", "test/out/"]
}
