{
  "name": "fumadocs-openapi",
  "version": "11.2.2",
  "description": "Generate MDX docs for your OpenAPI spec",
  "keywords": [
    "Docs",
    "fumadocs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "css",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./i18n": "./dist/i18n.js",
    "./playground/client": "./dist/playground/client.js",
    "./requests/generators": "./dist/requests/generators/index.js",
    "./requests/generators/all": "./dist/requests/generators/all.js",
    "./requests/generators/csharp": "./dist/requests/generators/csharp.js",
    "./requests/generators/curl": "./dist/requests/generators/curl.js",
    "./requests/generators/go": "./dist/requests/generators/go.js",
    "./requests/generators/java": "./dist/requests/generators/java.js",
    "./requests/generators/javascript": "./dist/requests/generators/javascript.js",
    "./requests/generators/python": "./dist/requests/generators/python.js",
    "./requests/generators/rust": "./dist/requests/generators/rust.js",
    "./scalar": "./dist/scalar/index.js",
    "./server": "./dist/server/index.js",
    "./ui": "./dist/ui/index.js",
    "./ui/base": "./dist/ui/base.js",
    "./ui/create-client": "./dist/ui/create-client.js",
    "./package.json": "./package.json",
    "./css/*": "./css/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fuma-translate/react": "^1.0.2",
    "@fumadocs/api-docs": "workspace:*",
    "@fumari/json-schema-ts": "^1.0.2",
    "@fumari/stf": "workspace:*",
    "@scalar/json-magic": "^0.12.17",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "github-slugger": "^2.0.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^1.24.0",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@scalar/api-client-react": "^2.0.33",
    "@scalar/openapi-upgrader": "^0.2.9",
    "@tailwindcss/oxide": "^4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "fast-content-type-parse": "^3.0.0",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:@fumadocs/base-ui@*",
    "json-schema-typed": "^8.0.2",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.8",
    "xml-js": "^1.6.11"
  },
  "peerDependencies": {
    "@scalar/api-client-react": "^2.0.20",
    "@types/react": "*",
    "fumadocs-core": "^16.10.0",
    "fumadocs-ui": "^16.10.0",
    "json-schema-typed": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "json-schema-typed": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "@scalar/api-client-react": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "@scalar/openapi-upgrader": "0.2.9",
    "fast-content-type-parse": "3.0.0",
    "xml-js": "1.6.11"
  }
}
