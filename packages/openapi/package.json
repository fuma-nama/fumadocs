{
  "name": "fumadocs-openapi",
  "version": "10.9.1",
  "description": "Generate MDX docs for your OpenAPI spec",
  "keywords": [
    "Docs",
    "NextJs"
  ],
  "homepage": "https://fumadocs.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fumadocs",
  "files": [
    "css",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./i18n": "./dist/i18n.js",
    "./playground/client": "./dist/playground/client.js",
    "./requests/generators": "./dist/requests/generators/index.js",
    "./requests/generators/all": "./dist/requests/generators/all.js",
    "./requests/generators/csharp": "./dist/requests/generators/csharp.js",
    "./requests/generators/curl": "./dist/requests/generators/curl.js",
    "./requests/generators/go": "./dist/requests/generators/go.js",
    "./requests/generators/java": "./dist/requests/generators/java.js",
    "./requests/generators/javascript": "./dist/requests/generators/javascript.js",
    "./requests/generators/python": "./dist/requests/generators/python.js",
    "./scalar": "./dist/scalar/index.js",
    "./server": "./dist/server/index.js",
    "./ui": "./dist/ui/index.js",
    "./ui/base": "./dist/ui/base.js",
    "./ui/client": "./dist/ui/client/index.js",
    "./ui/create-client": "./dist/ui/create-client.js",
    "./package.json": "./package.json",
    "./css/*": "./css/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fumari/json-schema-ts": "^0.0.2",
    "@fumari/stf": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "github-slugger": "^2.0.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.17.0",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@scalar/api-client-react": "2.0.20",
    "@scalar/json-magic": "^0.12.14",
    "@scalar/openapi-upgrader": "^0.2.8",
    "@tailwindcss/oxide": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "ajv": "^8.20.0",
    "fast-content-type-parse": "^3.0.0",
    "fumadocs-core": "workspace:*",
    "fumadocs-ui": "workspace:*",
    "json-schema-typed": "^8.0.2",
    "tailwindcss": "^4.3.0",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.0",
    "xml-js": "^1.6.11"
  },
  "peerDependencies": {
    "@scalar/api-client-react": "^2.0.20",
    "@types/react": "*",
    "fumadocs-core": "^16.9.0",
    "fumadocs-ui": "^16.9.0",
    "json-schema-typed": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "json-schema-typed": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "@scalar/api-client-react": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "@fastify/deepmerge": "3.2.1",
    "@scalar/helpers": "0.8.0",
    "@scalar/json-magic": "0.12.14",
    "@scalar/openapi-upgrader": "0.2.8",
    "ajv": "8.20.0",
    "fast-content-type-parse": "3.0.0",
    "fast-deep-equal": "3.1.3",
    "fast-uri": "3.1.0",
    "json-schema-traverse": "1.0.0",
    "pathe": "2.0.3",
    "xml-js": "1.6.11",
    "yaml": "2.9.0"
  }
}
